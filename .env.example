# SmartStore Intelligence — Environment Configuration
# Copy this file to .env and adjust values before running.

# Video source: webcam index (0), local file path, or RTSP URL
VIDEO_SOURCE=demo/mall_sample.mp4

# Number of concurrent people that triggers a queue alert
ALERT_THRESHOLD=8

# YOLOv8 detection confidence threshold (0.0 - 1.0)
CONFIDENCE=0.4

# Maximum frames to keep a lost track before purging
MAX_TRACK_AGE=30

# Heat map temporal decay per frame (0.99 = slow fade, 0.90 = fast fade)
HEATMAP_DECAY=0.995

# Input frame resolution (lower = faster inference)
FRAME_WIDTH=640
FRAME_HEIGHT=480

# Target WebSocket stream FPS
TARGET_FPS=15

# Rolling window for dwell time statistics (seconds)
DWELL_WINDOW_SEC=60

# Rolling window for peak count tracking (seconds)
PEAK_WINDOW_SEC=300
